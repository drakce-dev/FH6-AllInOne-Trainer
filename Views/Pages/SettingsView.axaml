<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FH6Mod.ViewModels.Pages"
             x:Class="FH6Mod.Views.Pages.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="20,16" Spacing="12">

            <!-- Preferences card -->
            <Border Classes="card">
                <StackPanel Spacing="10">
                    <TextBlock Text="PREFERENCES" Classes="section-header" />

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                        <TextBlock Grid.Column="0" Text="UI animations" VerticalAlignment="Center" FontSize="12" />
                        <ToggleSwitch Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"
                                      IsChecked="{Binding AnimationsEnabled, Mode=TwoWay}" />
                    </Grid>

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                        <TextBlock Grid.Column="0" Text="Mouse hover glow" VerticalAlignment="Center" FontSize="12" />
                        <ToggleSwitch Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"
                                      IsChecked="{Binding MouseGlowEnabled, Mode=TwoWay}" />
                    </Grid>

                    <!-- Accent color -->
                    <StackPanel Spacing="6" Margin="0,4,0,0">
                        <TextBlock Text="Accent color" FontSize="12" />
                        <ItemsControl ItemsSource="{Binding AccentOptions}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:AccentItemVm">
                                    <Button Background="Transparent" BorderThickness="0" Padding="0"
                                            Margin="0,0,8,8" Cursor="Hand"
                                            ToolTip.Tip="{Binding Name}"
                                            Click="OnAccentSwatchClick">
                                        <Border Classes="accentSwatch"
                                                Classes.selected="{Binding IsSelected}"
                                                Width="28" Height="28" CornerRadius="999"
                                                BorderThickness="2" Padding="3">
                                            <Border CornerRadius="999"
                                                    Background="{Binding Base, Converter={StaticResource HexToBrushConverter}}" />
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Diagnostics card -->
            <Border Classes="card">
                <StackPanel Spacing="10">
                    <TextBlock Text="DIAGNOSTICS" Classes="section-header" />

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <TextBlock Grid.Column="0" Text="Signature scan" VerticalAlignment="Center" FontSize="12" />
                        <Button Grid.Column="1" Content="Scan All" Classes="primary" Padding="12,4" FontSize="11"
                                IsEnabled="{Binding !IsScanning}"
                                Command="{Binding ScanSignaturesCommand}" />
                    </Grid>
                    <TextBox Text="{Binding ScanStatus}" IsReadOnly="True"
                             FontFamily="Consolas, Courier New, monospace" FontSize="10"
                             TextWrapping="Wrap" IsVisible="{Binding ScanStatus, Converter={StaticResource NotNullConverter}}"
                             MaxHeight="180" />

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <TextBlock Grid.Column="0" Text="Conflict detection" VerticalAlignment="Center" FontSize="12" />
                        <Button Grid.Column="1" Content="Detect" Classes="primary" Padding="12,4" FontSize="11"
                                Command="{Binding DetectConflictsCommand}" />
                    </Grid>
                    <Border IsVisible="{Binding HasConflicts}" Background="#33FF4444" CornerRadius="6" Padding="8,4">
                        <TextBlock Text="{Binding ConflictStatus}" TextWrapping="Wrap"
                                   Foreground="#FF6666" FontFamily="Consolas, Courier New, monospace" FontSize="10" />
                    </Border>
                    <Border IsVisible="{Binding ConflictStatus, Converter={StaticResource NotNullConverter}}"
                            Background="{DynamicResource Surface2Brush}" CornerRadius="6" Padding="8,4">
                        <TextBlock Text="{Binding ConflictStatus}" TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontFamily="Consolas, Courier New, monospace" FontSize="10" />
                    </Border>
                </StackPanel>
            </Border>

            <!-- Profiles card -->
            <Border Classes="card">
                <StackPanel Spacing="10">
                    <TextBlock Text="CHEAT PROFILES" Classes="section-header" />

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <TextBox Grid.Column="0" PlaceholderText="Profile name..."
                                 Text="{Binding ProfileName, Mode=TwoWay}" />
                        <Button Grid.Column="1" Content="Save" Classes="primary" Padding="12,4" FontSize="11"
                                Command="{Binding SaveProfileCommand}" />
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                        <ComboBox Grid.Column="0" ItemsSource="{Binding SavedProfiles}"
                                  SelectedItem="{Binding SelectedProfile, Mode=TwoWay}"
                                  PlaceholderText="Saved profiles..." />
                        <Button Grid.Column="1" Content="Load" Classes="ghost" Padding="10,4" FontSize="11"
                                Command="{Binding LoadProfileCommand}" />
                        <Button Grid.Column="2" Content="Delete" Classes="ghost" Padding="10,4" FontSize="11"
                                Command="{Binding DeleteProfileCommand}" />
                    </Grid>
                    <Button Content="Open profiles folder" Classes="ghost-sm" Padding="10,4"
                            HorizontalAlignment="Left"
                            Command="{Binding OpenProfilesFolderCommand}" />
                    <TextBlock Text="{Binding ProfileStatus}" Classes="dim" TextWrapping="Wrap"
                               IsVisible="{Binding ProfileStatus, Converter={StaticResource NotNullConverter}}" />
                </StackPanel>
            </Border>

            <!-- About card -->
            <Border Classes="card">
                <StackPanel Spacing="6">
                    <TextBlock Text="ABOUT" Classes="section-header" />
                    <TextBlock Classes="dim" TextWrapping="Wrap">
                        <Run Text="FH6 All-in-One Trainer · " />
                        <Run Text="{Binding VersionText}" />
                        <Run Text=" · GPL-3.0 · .NET 10 · Avalonia 12" />
                    </TextBlock>
                    <TextBlock Classes="dim" TextWrapping="Wrap">
                        Cheats by paris' club · UI by Chaarkor · Improvements by changcheng967 · discord.gg/WSd3bRNJuJ
                    </TextBlock>
                    <Button Content="Open settings folder" Classes="ghost-sm"
                            HorizontalAlignment="Left" Margin="0,4,0,0"
                            Command="{Binding OpenSettingsFolderCommand}" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
